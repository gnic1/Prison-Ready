{
  "expo": {
    "name": "Prison Ready",
    "slug": "prison-ready",
    "version": "1.0.0",
    "orientation": "portrait",
    "platforms": [
      "android",
      "web"
    ],
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      [
        "expo-location",
        {
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true,
          "locationWhenInUsePermission": "Allow Prison Ready to track your route while a mission is active.",
          "locationAlwaysAndWhenInUsePermission": "Allow Prison Ready to keep mission progress running while you walk, even when the app is backgrounded."
        }
      ],
      [
        "expo-notifications",
        {
          "defaultChannel": "mission-updates"
        }
      ],
      "expo-audio"
    ],
    "android": {
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "VIBRATE"
      ],
      "package": "com.prisonready.app",
      "config": {
        "googleMaps": {
          "apiKey": "REPLACE_WITH_ANDROID_MAPS_API_KEY"
        }
      }
    },
    "userInterfaceStyle": "light",
    "extra": {
      "eas": {
        "projectId": "82b01209-da97-407e-be96-9bc060e3bfd5"
      }
    }
  }
}
